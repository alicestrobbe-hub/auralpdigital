---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// PROGETTI — sorgente unica dei dati. Aggiungere un progetto = aggiungere un
// oggetto qui. `status: 'live'` → riga cliccabile con anteprima; `'soon'` →
// pannello chiaro (qui usato come invito: link interno ai contatti).
// `preview` è il path di uno screenshot in /public/projects/ (se vuoto,
// l'anteprima mostra un fondo brandizzato). `title` + `titleEm` → la seconda
// parte del titolo va in corsivo (accento editoriale). `desc` è la riga di
// descrizione nel pannello espanso, `cta` l'etichetta del link.
const projects = [
  {
    n: "01",
    title: "Alessia",
    titleEm: "PMU",
    type: "Beauty · Permanent Make-up",
    year: "2026",
    desc: "Sito editoriale fotografia-first per studio di trucco permanente.",
    cta: "Vedi il caso studio",
    url: "#", // TODO: URL live
    preview: "", // TODO: /projects/alessia.jpg
    status: "live" as const,
  },
  {
    n: "02",
    title: "Maria",
    titleEm: "Egger",
    type: "Tattoo Studio",
    year: "2026",
    desc: "Identità dark-luxe con motion legato allo scroll per studio tattoo.",
    cta: "Vedi il caso studio",
    url: "#", // TODO: URL live
    preview: "", // TODO: /projects/maria.jpg
    status: "live" as const,
  },
  {
    n: "03",
    title: "Il",
    titleEm: "prossimo.",
    type: "Spazio libero",
    year: "",
    desc: "Questo spazio è libero: il prossimo caso studio potrebbe essere il tuo.",
    cta: "Inizia da qui",
    url: "#contatti",
    preview: "",
    status: "soon" as const,
  },
];

// SERVIZI — sorgente unica dei dati della sezione "Cosa Facciamo".
// Ogni servizio è una "scena" a tutta schermata nella sezione pinnata:
// titolo con coda in corsivo (`nameEm`), descrizione, chip di competenze e
// un placeholder immagine (`grad` è la cover brandizzata in attesa del visual).
const services = [
  {
    n: "01",
    name: "Siti web",
    nameEm: "che convertono.",
    desc: "Ultra-moderni, veloci e impeccabili su mobile. Ottimizzati per Google e per le ricerche AI (SEO + GEO), con intelligenza artificiale integrata e ogni dettaglio progettato per trasformare i visitatori in clienti.",
    tags: ["SEO + GEO", "AI integrata", "Mobile-first", "Conversione"],
    grad: "grad-2",
    art: "web",
  },
  {
    n: "02",
    name: "Gestionali",
    nameEm: "su misura.",
    desc: "Sistemi costruiti attorno ai tuoi processi: dati centralizzati e sempre sotto controllo, ogni lead seguito fino in fondo. Potenziati dall'AI, per completare più lavoro in meno tempo.",
    tags: ["Dati centralizzati", "Lead management", "AI augmented"],
    grad: "grad-1",
    art: "ops",
  },
  {
    n: "03",
    name: "Social",
    nameEm: "che vendono.",
    desc: "Strategia e contenuti per far crescere il traffico organico, campagne ads mirate per trasformarlo in clienti: il tuo brand davanti alle persone giuste, al momento giusto.",
    tags: ["Contenuti organici", "Meta & Google Ads", "Strategia"],
    grad: "grad-3",
    art: "social",
  },
];

const marqueeItems = [
  "Siti Web",
  "Gestionali su misura",
  "Social & Ads",
  "SEO + GEO",
  "AI Integration",
  "Lead Generation",
];
---

<BaseLayout>
  <Navbar home />

  <!-- HERO — sezione a tutta schermo, scroll normale -->
  <section class="hero-section relative h-screen w-full overflow-hidden" data-anim="hero">
    <video
      data-anim="hero-video"
      autoplay
      muted
      playsinline
      preload="auto"
      class="hero-video absolute inset-0 w-full h-full object-cover"
      style="opacity: 0;"
    >
      <source src="/videos/hf_20260530_204233_c0117512-9162-41ec-a063-b269b29ab4e7.mp4" type="video/mp4" />
    </video>

    <!-- Layer 1 — overlay caldo: scalda il grigio freddo del video verso il warm white -->
    <div class="hero-warm-overlay absolute inset-0 z-[1] pointer-events-none"></div>

    <!-- Layer 2 — fusione ai bordi: vignettatura calda che fa "emergere" il video dalla pagina -->
    <div class="hero-edge-fade absolute inset-0 z-[2] pointer-events-none"></div>

    <!-- Layer 3 — fade in fondo: il video sfuma nel warm white della sezione progetti -->
    <div class="hero-bottom-fade absolute inset-x-0 bottom-0 z-[3] pointer-events-none"></div>

    <!-- Segni di stampa — forme di palette che fluttuano ai margini della scena -->
    <div class="hero-deco absolute inset-0 z-[4] pointer-events-none" aria-hidden="true">
      <span class="deco deco--ring deco-peri deco-float-1" style="left: 11%; top: 26%;"></span>
      <span class="deco deco--plus deco-accent deco-float-2" style="right: 13%; top: 32%;"></span>
      <span class="deco deco--dot deco-navy deco-float-3" style="left: 17%; bottom: 24%;"></span>
      <span class="deco deco--star deco-muted deco-float-2" style="right: 19%; bottom: 30%;">✦</span>
    </div>

    <div data-anim="hero-content" class="relative z-10 flex flex-col items-center justify-center h-full px-6 text-center" style="background: radial-gradient(ellipse 50% 38% at 50% 50%, rgba(250, 250, 248, 0.85) 0%, rgba(250, 250, 248, 0.7) 35%, rgba(250, 250, 248, 0.35) 65%, transparent 90%);">
      <span
        data-anim="hero-label"
        class="hero-badge text-[11px] font-medium tracking-[0.15em] uppercase"
        style="opacity: 0;"
      >
        Digital Growth Studio · Alto Adige
      </span>

      <h1
        class="font-display font-medium text-[#0D0D0D] mt-6"
        style="font-size: clamp(38px, 5vw, 80px); line-height: 0.98; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), 0 4px 16px rgba(0, 0, 0, 0.2);"
      >
        <span data-anim="hero-line-1" class="block" style="opacity: 0;">Sistemi digitali</span>
        <span data-anim="hero-line-2" class="block" style="opacity: 0;">di <em class="hero-circled" style="font-style: italic; color: #3B5BDB;">prossima<svg class="circle-sketch" viewBox="0 0 240 90" preserveAspectRatio="none" aria-hidden="true"><path d="M125 9 C 192 6, 233 23, 231 46 C 229 71, 174 85, 115 83 C 57 81, 8 67, 10 44 C 12 22, 62 7, 140 10" /></svg></em></span>
        <span data-anim="hero-line-3" class="block" style="opacity: 0;">generazione.</span>
      </h1>

      <p
        data-anim="hero-subline"
        class="mt-5 text-[14px] tracking-[0.04em] text-[#4A4A4A]"
        style="opacity: 0; text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);"
      >
        Siti web, gestionali e social che trasformano visitatori in clienti.
      </p>

      <div
        data-anim="hero-cta"
        class="mt-8 flex flex-col sm:flex-row items-center gap-3 sm:gap-7"
        style="opacity: 0;"
      >
        <a
          href="#projects"
          class="pill text-[13px] px-7 py-[14px]"
        >
          Esplora il nostro lavoro <span aria-hidden="true">↗</span>
        </a>
        <a href="#contatti" class="hero-link">
          Prenota una consulenza <span aria-hidden="true">↗</span>
        </a>
      </div>

      <!-- Hint di scroll — hairline con tratto accent che scorre in loop. -->
      <div class="hero-scroll-hint" data-anim="hero-hint" style="opacity: 0;" aria-hidden="true">
        <span class="hero-scroll-label">Scorri</span>
        <span class="hero-scroll-line"></span>
      </div>
    </div>
  </section>

  <!-- CONTENUTO — flusso normale -->
  <div class="post-reveal relative z-10">

  <!-- SECTION — PROGETTI -->
  <section id="projects" class="projects-section">
    <!-- Curve di livello — la "mappa" del territorio, in parallasse leggera. -->
    <div class="section-topo" aria-hidden="true" data-parallax="0.14">
      <svg viewBox="0 0 420 320" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M210 18c104-4 190 60 188 144-2 82-90 142-190 140S20 242 22 158C24 76 112 22 210 18Z" stroke="rgba(154, 163, 178, 0.5)" />
        <path d="M212 52c80-3 152 46 152 108 0 64-72 112-154 110S58 222 60 160C62 100 134 55 212 52Z" stroke="rgba(59, 91, 219, 0.32)" />
        <path d="M214 88c56-2 116 30 118 72 2 44-54 80-120 78-66-2-120-34-118-78 2-42 64-70 120-72Z" stroke="rgba(138, 160, 255, 0.5)" />
        <path d="M210 126c36-2 66 16 66 36s-30 38-66 36c-34-2-62-16-62-36s28-34 62-36Z" stroke="rgba(26, 35, 64, 0.4)" />
        <circle cx="211" cy="162" r="3" fill="#3B5BDB" />
      </svg>
    </div>
    <span class="deco deco--star deco-accent deco-float-2" style="left: 4.5%; bottom: 5%;" aria-hidden="true">✦</span>
    <div class="works-screen">
      <!-- Header pulito: kicker con tick accent, titolo, link essenziale. -->
      <div class="works-head" data-anim="works-head">
        <div class="works-head-left">
          <span class="works-kicker">Lavori selezionati<span class="kicker-index">01</span></span>
          <h2 class="works-title">Cosa <em>abbiamo creato.</em></h2>
        </div>
        <a href="#contatti" class="works-head-link">
          Il prossimo è il tuo <span aria-hidden="true">↗</span>
        </a>
      </div>

      <!-- RAIL — pannelli espandibili in hover. Il primo è aperto di default;
           passando il mouse su un altro, quello si espande e gli altri si stringono. -->
      <div class="works-rail">
        {projects.map((p, i) => {
          const Tag = p.url ? "a" : "div";
          const props = !p.url
            ? { "aria-disabled": "true" }
            : p.url.startsWith("#")
              ? { href: p.url }
              : { href: p.url, target: "_blank", rel: "noopener noreferrer" };
          return (
            <Tag
              class={`work-panel grad-${(i % 4) + 1}${p.status === "soon" ? " work-panel--soon" : ""}`}
              data-open={i === 0 ? "" : undefined}
              data-anim="work-panel"
              {...props}
            >
              {p.preview && (
                <img class="work-panel-img" src={p.preview} alt={p.title} loading="lazy" />
              )}
              <span class="work-panel-scrim" aria-hidden="true"></span>

              {/* Stato collassato — numero in alto, titolo verticale in basso */}
              <div class="panel-vertical">
                <span class="panel-vertical-num">{p.n}</span>
                <span class="panel-vertical-title">{p.title} {p.titleEm}</span>
              </div>

              {/* Stato espanso — contenuto editoriale */}
              <div class="panel-full">
                <span class="panel-index" aria-hidden="true">{p.n}</span>
                <div class="panel-body">
                  <span class="panel-kicker">
                    <span class="panel-tick" aria-hidden="true"></span>
                    {p.type}{p.year ? ` · ${p.year}` : ""}
                  </span>
                  <h3 class="panel-title">
                    {p.title} <em>{p.titleEm}</em>
                  </h3>
                  {p.desc && <p class="panel-desc">{p.desc}</p>}
                  {p.url && p.cta && (
                    <span class="panel-cta">
                      <span class="panel-cta-label">{p.cta}</span>
                      <span class="panel-cta-arrow" aria-hidden="true">↗</span>
                    </span>
                  )}
                </div>
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- SECTION — COSA FACCIAMO — banda navy. Il colore non sta sulla sezione
       ma sul canvas .post-reveal: uno scrub GSAP scurisce l'intero schermo
       verso il navy mentre si scrolla da "Lavori selezionati" a qui (e poi
       torna chiaro verso "Chi Siamo"). Il bg statico della sezione resta
       come fallback per reduced-motion / no-JS. Su desktop la sezione viene
       PINNATA e i servizi si rivelano uno a uno in scrub (vedi main.ts). -->
  <section id="cosa-facciamo" class="services-section">
    <!-- Aurora sul navy — due bagliori jewel-tone che derivano piano. -->
    <div class="services-glow services-glow--1" aria-hidden="true"></div>
    <div class="services-glow services-glow--2" aria-hidden="true"></div>
    <!-- Crinale alpino — doppia linea di cresta in fondo alla banda. -->
    <svg class="services-ridge" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 96 120 58l90 28 130-60 110 44 150-68 130 56 120-30 110 44 150-58 130 40 90-22" stroke="rgba(250, 250, 248, 0.13)" fill="none" stroke-width="1.5" />
      <path d="M0 112 140 78l100 22 140-48 120 38 160-56 140 46 130-26 120 38 150-46 140 32 100-18" stroke="rgba(138, 160, 255, 0.25)" fill="none" stroke-width="1" />
    </svg>
    <div class="works-screen">
      <div class="works-head" data-anim="services-head">
        <div class="works-head-left">
          <span class="works-kicker">Cosa facciamo<span class="kicker-index">02</span></span>
          <h2 class="works-title">Servizi che <em>fanno crescere.</em></h2>
        </div>
        <a href="#contatti" class="works-head-link">
          Parliamone <span aria-hidden="true">↗</span>
        </a>
      </div>

      <!-- SCENE SERVIZIO — una per servizio, a tutta schermata: su desktop
           la sezione è pinnata e le scene si avvicendano scrollando (titolo
           dalla maschera, descrizione e chip in coda, placeholder immagine
           che si solleva); su mobile scorrono in colonna e si rivelano
           entrando in viewport (vedi main.ts). -->
      <div class="services-stage">
        {services.map((s) => (
          <article class="service-slide">
            <div class="slide-body">
              <span class="slide-index">{s.n} / 0{services.length}</span>
              <h3 class="slide-title">
                <span class="sn-mask"><span class="sn">{s.name} <em>{s.nameEm}</em></span></span>
              </h3>
              <p class="slide-desc">{s.desc}</p>
              <div class="slide-tags">
                {s.tags.map((t) => <span class="slide-tag">{t}</span>)}
              </div>
            </div>
            <div class={`slide-media grain ${s.grad}`}>
              <span class="slide-media-num font-display" aria-hidden="true">{s.n}</span>
              {s.art === "web" && (
                <div class="media-art" aria-hidden="true">
                  <span class="art-frame">
                    <span class="art-frame-bar">
                      <span class="art-dot"></span>
                      <span class="art-dot"></span>
                      <span class="art-dot"></span>
                    </span>
                    <span class="art-line art-line--lg"></span>
                    <span class="art-line art-line--accent"></span>
                    <span class="art-line art-line--sm"></span>
                    <span class="art-chip"></span>
                  </span>
                </div>
              )}
              {s.art === "ops" && (
                <div class="media-art media-art--ops" aria-hidden="true">
                  <span class="art-row">
                    <span class="art-cell art-cell--on"></span>
                    <span class="art-bar art-bar--70"></span>
                  </span>
                  <span class="art-row">
                    <span class="art-cell"></span>
                    <span class="art-bar art-bar--50"></span>
                  </span>
                  <span class="art-row">
                    <span class="art-cell art-cell--on"></span>
                    <span class="art-bar art-bar--85"></span>
                  </span>
                  <span class="art-row">
                    <span class="art-cell"></span>
                    <span class="art-bar art-bar--40"></span>
                  </span>
                </div>
              )}
              {s.art === "social" && (
                <div class="media-art" aria-hidden="true">
                  <span class="art-orbit art-orbit--1"></span>
                  <span class="art-orbit art-orbit--2"></span>
                  <span class="art-orbit art-orbit--3"></span>
                  <span class="art-core"></span>
                  <span class="art-sat art-sat--1"></span>
                  <span class="art-sat art-sat--2"></span>
                  <span class="art-sat art-sat--3"></span>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="services-scroll-hint" aria-hidden="true" style="opacity: 0;">
      <span class="services-scroll-label">Scorri</span>
      <span class="services-scroll-line"></span>
    </div>

  </section>

  <!-- SECTION — CHI SIAMO — scena cinematografica: il video dello Sciliar
       in bianco e nero fa da fondale (sticky a tutta viewport, fuso nel
       canvas da una mask verticale + velo radiale — vedi .about-video-frame
       in global.css); sopra, lo statement pinnato che si riempie lettera
       per lettera in scrub mentre la montagna emerge dal velo (vedi
       [data-glow-pin] in main.ts). In coda la firma dello studio come
       ponte verso /chi-siamo. -->
  <section id="chi-siamo" class="about-section">
    <div class="about-backdrop" aria-hidden="true">
      <div class="about-video-frame">
        <video
          class="about-video"
          data-about-video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src="/videos/sciliar.mp4" type="video/mp4" />
        </video>
        <div class="about-video-veil" data-about-veil></div>
      </div>
    </div>

    <!-- INTRO PINNATA — arrivati qui la pagina si blocca (pin GSAP): lo
         scroll riempie le lettere da grigio a colorato una a una mentre
         il velo sul video si dirada, poi lo scroll riprende normale.
         Figlia diretta della sezione: il pin-spacer di GSAP non convive
         con un genitore flex. -->
    <div class="about-intro about-content">
      <span class="deco deco--star deco-peri deco-float-1" style="right: 13%; top: 26%;" aria-hidden="true">✦</span>
      <span class="deco deco--ring deco-accent deco-float-3" style="left: 11%; bottom: 27%;" aria-hidden="true"></span>
      <div class="works-screen about-intro-screen">
        <span class="works-kicker about-kicker" data-anim="about-kicker">Chi siamo<span class="kicker-index">03</span></span>
        <p class="about-statement font-display" data-glow-pin>
          Uno studio indipendente che unisce
          <em>rigore universitario</em> e strumenti di nuova generazione:
          ogni progetto seguito <em>dalle stesse mani</em>,
          dal primo sketch al lancio
        </p>
      </div>
    </div>

    <!-- FIRMA — chiusura di scena: lo statement-manifesto dello studio
         in scala monumentale, ponte verso /chi-siamo. -->
    <div class="about-outro about-content">
      <span class="deco deco--plus deco-accent deco-float-2" style="left: 15%; top: 16%;" aria-hidden="true"></span>
      <span class="deco deco--ring deco-peri deco-float-1" style="right: 13%; bottom: 32%;" aria-hidden="true"></span>
      <a href="/chi-siamo" class="about-duo" data-anim="duo">
        <span class="duo-names font-display">Persone, <em>non</em> agenzie.</span>
        <span class="duo-cta">
          Nessun intermediario · Conosci lo studio
          <span aria-hidden="true">↗</span>
        </span>
      </a>
    </div>
  </section>

  <!-- MARQUEE — nastro infinito di competenze, transizione verso la CTA. -->
  <div class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <span class="marquee-item font-display">
          {item}<span class="marquee-star">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- SECTION — CTA FINALE -->
  <section id="contatti" class="cta-section" data-anim="contact">
    <div class="cta-panel grain">
      <!-- Spotlight — alone accent che segue il cursore (vedi main.ts). -->
      <div class="cta-spotlight" aria-hidden="true"></div>
      <!-- Retino di punti — texture "stampa" periwinkle nell'angolo. -->
      <div class="cta-dots" aria-hidden="true"></div>
      <span class="works-kicker cta-kicker" data-anim="contact-kicker">
        Iniziamo<span class="kicker-index">04</span>
      </span>

      <h2 class="cta-title" data-anim="contact-headline">
        Costruiamo il tuo<br />
        <em>sistema di crescita.</em>
      </h2>

      <p class="cta-sub" data-anim="contact-sub">
        Prenota una consulenza gratuita di 30 minuti: nessun impegno,
        solo idee chiare su come far crescere la tua attività online.
      </p>

      <div class="cta-actions" data-anim="contact-cta">
        <a href="mailto:hello@auralpdigital.com" class="cta-pill magnetic">
          Prenota la consulenza <span aria-hidden="true">↗</span>
        </a>
        <a href="mailto:hello@auralpdigital.com" class="cta-mail">
          hello@auralpdigital.com
        </a>
      </div>

      <div class="cta-foot" data-anim="contact-cta">
        <span>Risposta entro 24 ore</span>
        <span class="cta-foot-dot" aria-hidden="true"></span>
        <span>Nessun impegno</span>
        <span class="cta-foot-dot" aria-hidden="true"></span>
        <span>Budget chiari da subito</span>
      </div>

      <span class="cta-star" aria-hidden="true">✦</span>
    </div>
  </section>

  <Footer home />

  </div>
  <!-- /post-reveal -->
</BaseLayout>
